# Mem0 Server 配置文件
# 复制此文件为 .env 并根据实际情况修改

# ============================================================
# 向量存储配置
# ============================================================
# FAISS 向量存储路径（相对路径或绝对路径）
FAISS_PATH=./data/faiss_memories

# ============================================================
# LLM 配置 (使用 Ollama 协议连接本地 LLM)
# ============================================================
# LLM 服务地址（LM Studio 默认为 1234 端口，Ollama 默认为 11434 端口）
OLLAMA_BASE_URL=http://localhost:1234

# 模型名称（根据实际使用的模型设置）
# LM Studio: 通常设置为 "local-model"
# Ollama: 设置为具体模型名，如 "qwen2.5:7b"
OLLAMA_MODEL=local-model

# LLM 温度（0.0-1.0，越低越确定）
OLLAMA_TEMPERATURE=0.1

# LLM 最大 token 数
OLLAMA_MAX_TOKENS=2000

# ============================================================
# Embedder 配置
# ============================================================
# Embedder 模型名称
# 如果使用 OpenAI: text-embedding-3-small
# 如果使用本地模型：根据服务提供方设置
EMBEDDER_MODEL=text-embedding-3-small

# Embedder API Key
# 本地服务可以设置为任意值
EMBEDDER_API_KEY=not-needed

# Embedder 服务地址（如果与 LLM 不同，可以单独设置）
# EMBEDDER_BASE_URL=http://localhost:1234

# ============================================================
# 服务器配置
# ============================================================
# 服务器监听地址
SERVER_HOST=0.0.0.0

# 服务器端口
SERVER_PORT=8000

# 日志级别 (debug, info, warning, error)
LOG_LEVEL=info

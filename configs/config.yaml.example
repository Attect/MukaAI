# MukaAI Configuration Template
# Copy this file to config.yaml and modify as needed
# Environment variables can override settings using MUKAAI_<SECTION>_<KEY> format
# Example: MUKAAI_MODEL_ENDPOINT=http://localhost:8080/v1/

model:
  endpoint: "http://127.0.0.1:11453/v1/"
  api_key: "your-api-key-here"
  model_name: "your-model-name"
  context_size: 200000

agent:
  max_iterations: 100
  temperature: 0.7

state:
  dir: "./state"
  auto_save: true

tools:
  work_dir: "."
  # 用户特别指定的命令白名单
  # 常见构建命令（gcc、cargo、node、npm、python、java等）由安全审查器自动包含
  # 不在白名单中的命令会通过安全审查器检查，非危险命令会在CLI模式下询问确认
  allow_commands:
    - "go"
    - "git"
    - "ls"
    - "cat"
    - "mkdir"
    - "rm"

# MCP (Model Context Protocol) 配置
# 启用后可连接外部MCP Server获取工具
mcp:
  enabled: false
  # MCP Server列表
  servers: []
  # Example MCP Server configurations:
  # servers:
  #   - id: "idea"
  #     enabled: true
  #     transport: "http"
  #     url: "http://127.0.0.1:64342/stream"
  #     timeout: 60
  #
  #   - id: "idea_stdio"
  #     enabled: true
  #     transport: "stdio"
  #     command: "/path/to/java"
  #     args:
  #       - "-classpath"
  #       - "/path/to/classpath"
  #       - "com.intellij.mcpserver.stdio.McpStdioRunnerKt"
  #     env:
  #       IJ_MCP_SERVER_PORT: "64342"
  #     timeout: 60

# 安全策略
security:
  default_policy: "allow"  # allow | confirm | deny
  # deny_tools:
  #   - "mcp_*_exec_*"
  # confirm_tools:
  #   - "mcp_*_delete_*"
  #   - "mcp_*_write_*"

# LSP (Language Server Protocol) 配置
# 启用后支持代码诊断（Go/TypeScript/Python）
lsp:
  enabled: false
  idle_timeout: 600  # 空闲10分钟自动关闭语言服务器
  servers:
    go:
      command: "gopls"
    typescript:
      command: "typescript-language-server"
      args: ["--stdio"]
    python:
      command: "pylsp"

{"timestamp":"2026-04-07T15:11:12.600981+08:00","type":"tool_call","content":"调用工具: write_file","metadata":{"arguments":"{\"content\":\"\u003c!DOCTYPE html\u003e\\n\u003chtml lang=\\\"zh-CN\\\"\u003e\\n\u003chead\u003e\\n    \u003cmeta charset=\\\"UTF-8\\\"\u003e\\n    \u003cmeta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\"\u003e\\n    \u003ctitle\u003e内网工具工作台\u003c/title\u003e\\n    \u003cstyle\u003e\\n        * {\\n            margin: 0;\\n            padding: 0;\\n            box-sizing: border-box;\\n        }\\n\\n        body {\\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\\n            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\\n            height: 100vh;\\n            overflow: hidden;\\n        }\\n\\n        .workspace {\\n            display: flex;\\n            height: 100vh;\\n            width: 100vw;\\n        }\\n\\n        /* 左侧工具栏 */\\n        .sidebar {\\n            width: 250px;\\n            background: #2c3e50;\\n            color: white;\\n            display: flex;\\n            flex-direction: column;\\n            box-shadow: 2px 0 10px rgba(0,0,0,0.3);\\n        }\\n\\n        .sidebar-header {\\n            padding: 20px;\\n            background: #1a252f;\\n            text-align: center;\\n        }\\n\\n        .sidebar-header h2 {\\n            font-size: 18px;\\n            color: #3498db;\\n        }\\n\\n        .tool-list {\\n            flex: 1;\\n            overflow-y: auto;\\n            padding: 10px;\\n        }\\n\\n        .tool-item {\\n            display: flex;\\n            align-items: center;\\n            justify-content: space-between;\\n            padding: 12px 15px;\\n            margin-bottom: 8px;\\n            background: #34495e;\\n            border-radius: 8px;\\n            cursor: pointer;\\n            transition: all 0.3s ease;\\n        }\\n\\n        .tool-item:hover {\\n            background: #3d566e;\\n            transform: translateX(5px);\\n        }\\n\\n        .tool-item.active {\\n            background: #3498db;\\n            color: white;\\n        }\\n\\n        .tool-item .name {\\n            display: flex;\\n            align-items: center;\\n            gap: 10px;\\n            font-size: 14px;\\n        }\\n\\n        .tool-item .icon {\\n            width: 32px;\\n            height: 32px;\\n            background: rgba(255,255,255,0.2);\\n            border-radius: 6px;\\n            display: flex;\\n            align-items: center;\\n            justify-content: center;\\n            font-size: 16px;\\n        }\\n\\n        .tool-item .close-btn {\\n            width: 24px;\\n            height: 24px;\\n            border: none;\\n            background: #e74c3c;\\n            color: white;\\n            border-radius: 50%;\\n            cursor: pointer;\\n            display: flex;\\n            align-items: center;\\n            justify-content: center;\\n            font-size: 14px;\\n            transition: all 0.3s ease;\\n        }\\n\\n        .tool-item .close-btn:hover {\\n            background: #c0392b;\\n            transform: scale(1.1);\\n        }\\n\\n        .tool-item .close-btn.hidden {\\n            display: none;\\n        }\\n\\n        /* 右侧内容区 */\\n        .main-content {\\n            flex: 1;\\n            padding: 20px;\\n            overflow-y: auto;\\n        }\\n\\n        /* 首页卡片样式 */\\n        .home-page {\\n            max-width: 1200px;\\n            margin: 0 auto;\\n        }\\n\\n        .home-title {\\n            text-align: center;\\n            color: white;\\n            margin-bottom: 40px;\\n        }\\n\\n        .home-title h1 {\\n            font-size: 36px;\\n            margin-bottom: 10px;\\n            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);\\n        }\\n\\n        .home-title p {\\n            font-size: 16px;\\n            opacity: 0.9;\\n        }\\n\\n        .tool-cards {\\n            display: grid;\\n            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));\\n            gap: 25px;\\n        }\\n\\n        .tool-card {\\n            background: white;\\n            border-radius: 15px;\\n            padding: 30px;\\n            box-shadow: 0 10px 30px rgba(0,0,0,0.2);\\n            transition: all 0.3s ease;\\n            cursor: pointer;\\n        }\\n\\n        .tool-card:hover {\\n            transform: translateY(-10px);\\n            box-shadow: 0 15px 40px rgba(0,0,0,0.3);\\n        }\\n\\n        .tool-card .card-icon {\\n            width: 70px;\\n            height: 70px;\\n            border-radius: 50%;\\n            display: flex;\\n            align-items: center;\\n            justify-content: center;\\n            font-size: 32px;\\n            margin-bottom: 20px;\\n        }\\n\\n        .tool-card.base64 .card-icon {\\n            background: linear-gradient(135deg, #667eea, #764ba2);\\n            color: white;\\n        }\\n\\n        .tool-card.json .card-icon {\\n            background: linear-gradient(135deg, #f093fb, #f5576c);\\n            color: white;\\n        }\\n\\n        .tool-card.timestamp .card-icon {\\n            background: linear-gradient(135deg, #4facfe, #00f2fe);\\n            color: white;\\n        }\\n\\n        .tool-card h3 {\\n            font-size: 22px;\\n            margin-bottom: 10px;\\n            color: #2c3e50;\\n        }\\n\\n        .tool-card p {\\n            color: #7f8c8d;\\n            line-height: 1.6;\\n        }\\n\\n        /* 工具页面通用样式 */\\n        .tool-page {\\n            background: white;\\n            border-radius: 15px;\\n            padding: 30px;\\n            box-shadow: 0 10px 30px rgba(0,0,0,0.2);\\n            max-width: 1200px;\\n            margin: 0 auto;\\n        }\\n\\n        .tool-page-header {\\n            display: flex;\\n            align-items: center;\\n            gap: 15px;\\n            margin-bottom: 30px;\\n            padding-bottom: 20px;\\n            border-bottom: 2px solid #ecf0f1;\\n        }\\n\\n        .tool-page-header .page-icon {\\n            width: 50px;\\n            height: 50px;\\n            border-radius: 50%;\\n            display: flex;\\n            align-items: center;\\n            justify-content: center;\\n            font-size: 24px;\\n        }\\n\\n        .tool-page-header h2 {\\n            font-size: 24px;\\n            color: #2c3e50;\\n        }\\n\\n        .tool-section {\\n            margin-bottom: 25px;\\n        }\\n\\n        .tool-section h3 {\\n            font-size: 18px;\\n            color: #34495e;\\n            margin-bottom: 15px;\\n            display: flex;\\n            align-items: center;\\n            gap: 8px;\\n        }\\n\\n        .input-group {\\n            margin-bottom: 15px;\\n        }\\n\\n        .input-group label {\\n            display: block;\\n            font-weight: 600;\\n            color: #34495e;\\n            margin-bottom: 8px;\\n        }\\n\\n        .input-group textarea,\\n        .input-group input {\\n            width: 100%;\\n            padding: 12px;\\n            border: 2px solid #ecf0f1;\\n            border-radius: 8px;\\n            font-size: 14px;\\n            transition: all 0.3s ease;\\n        }\\n\\n        .input-group textarea:focus,\\n        .input-group input:focus {\\n            outline: none;\\n            border-color: #3498db;\\n            box-shadow: 0 0 0 3px rgba(52,152,219,0.1);\\n        }\\n\\n        .input-group textarea {\\n            min-height: 150px;\\n            resize: vertical;\\n        }\\n\\n        .btn-group {\\n            display: flex;\\n            gap: 10px;\\n            flex-wrap: wrap;\\n        }\\n\\n        .btn {\\n            padding: 12px 24px;\\n            border: none;\\n            border-radius: 8px;\\n            font-size: 14px;\\n            font-weight: 600;\\n            cursor: pointer;\\n            transition: all 0.3s ease;\\n            display: flex;\\n            align-items: center;\\n            gap: 8px;\\n        }\\n\\n        .btn-primary {\\n            background: linear-gradient(135deg, #667eea, #764ba2);\\n            color: white;\\n        }\\n\\n        .btn-primary:hover {\\n            transform: translateY(-2px);\\n            box-shadow: 0 5px 15px rgba(102,126,234,0.4);\\n        }\\n\\n        .btn-secondary {\\n            background: #95a5a6;\\n            color: white;\\n        }\\n\\n        .btn-secondary:hover {\\n            background: #7f8c8d;\\n        }\\n\\n        .btn-success {\\n            background: linear-gradient(135deg, #11998e, #38ef7d);\\n            color: white;\\n        }\\n\\n        .btn-success:hover {\\n            transform: translateY(-2px);\\n            box-shadow: 0 5px 15px rgba(17,153,142,0.4);\\n        }\\n\\n        .result-area {\\n            background: #f8f9fa;\\n            border: 2px solid #ecf0f1;\\n            border-radius: 8px;\\n            padding: 20px;\\n            margin-top: 20px;\\n        }\\n\\n        .result-area h4 {\\n            color: #34495e;\\n            margin-bottom: 10px;\\n            font-size: 16px;\\n        }\\n\\n        .result-content {\\n            background: white;\\n            border-radius: 6px;\\n            padding: 15px;\\n            min-height: 100px;\\n            max-height: 300px;\\n            overflow-y: auto;\\n            font-family: 'Courier New', monospace;\\n            font-size: 14px;\\n            line-height: 1.6;\\n            white-space: pre-wrap;\\n            word-break: break-all;\\n        }\\n\\n        .result-content.error {\\n            background: #fee;\\n            color: #c0392b;\\n        }\\n\\n        .result-content.success {\\n            background: #e8f5e9;\\n            color: #27ae60;\\n        }\\n\\n        /* 对比工具样式 */\\n        .compare-container {\\n            display: grid;\\n            grid-template-columns: 1fr 1fr;\\n            gap: 20px;\\n        }\\n\\n        .compare-panel {\\n            background: #f8f9fa;\\n            border-radius: 8px;\\n            padding: 20px;\\n        }\\n\\n        .compare-panel h4 {\\n            color: #34495e;\\n            margin-bottom: 15px;\\n            text-align: center;\\n        }\\n\\n        /* 状态提示 */\\n        .status-bar {\\n            padding: 10px 20px;\\n            background: #ecf0f1;\\n            border-radius: 8px;\\n            margin-top: 15px;\\n            font-size: 14px;\\n        }\\n\\n        .status-bar.success {\\n            background: #d5f5e3;\\n            color: #27ae60;\\n        }\\n\\n        .status-bar.error {\\n            background: #fdebd0;\\n            color: #d35400;\\n        }\\n\\n        /* 隐藏类 */\\n        .hidden {\\n            display: none !important;\\n        }\\n\\n        /* 滚动条样式 */\\n        ::-webkit-scrollbar {\\n            width: 8px;\\n            height: 8px;\\n        }\\n\\n        ::-webkit-scrollbar-track {\\n            background: #ecf0f1;\\n            border-radius: 4px;\\n        }\\n\\n        ::-webkit-scrollbar-thumb {\\n            background: #bdc3c7;\\n            border-radius: 4px;\\n        }\\n\\n        ::-webkit-scrollbar-thumb:hover {\\n            background: #95a5a6;\\n        }\\n\\n        /* 工具提示 */\\n        .tooltip {\\n            position: relative;\\n        }\\n\\n        .tooltip:hover::after {\\n            content: attr(data-tooltip);\\n            position: absolute;\\n            bottom: 100%;\\n            left: 50%;\\n            transform: translateX(-50%);\\n            background: #2c3e50;\\n            color: white;\\n            padding: 8px 12px;\\n            border-radius: 6px;\\n            font-size: 12px;\\n            white-space: nowrap;\\n            z-index: 100;\\n        }\\n\\n        /* JSON 格式化高亮 */\\n        .json-highlight {\\n            font-family: 'Courier New', monospace;\\n            line-height: 1.6;\\n        }\\n\\n        .json-key { color: #881391; }\\n        .json-string { color: #0b752e; }\\n        .json-number { color: #1a01cc; }\\n        .json-boolean { color: #ff6b68; }\\n        .json-null { color: #808080; font-style: italic; }\\n\\n        /* 响应式设计 */\\n        @media (max-width: 768px) {\\n            .sidebar {\\n                width: 200px;\\n            }\\n            \\n            .tool-cards {\\n                grid-template-columns: 1fr;\\n            }\\n\\n            .compare-container {\\n                grid-template-columns: 1fr;\\n            }\\n        }\\n    \u003c/style\u003e\\n\u003c/head\u003e\\n\u003cbody\u003e\\n    \u003cdiv class=\\\"workspace\\\"\u003e\\n        \u003c!-- 左侧工具栏 --\u003e\\n        \u003caside class=\\\"sidebar\\\"\u003e\\n            \u003cdiv class=\\\"sidebar-header\\\"\u003e\\n                \u003ch2\u003e🛠️ 内网工具工作台\u003c/h2\u003e\\n            \u003c/div\u003e\\n            \u003cdiv class=\\\"tool-list\\\" id=\\\"toolList\\\"\u003e\\n                \u003c!-- 动态生成的工具列表 --\u003e\\n            \u003c/div\u003e\\n        \u003c/aside\u003e\\n\\n        \u003c!-- 右侧内容区 --\u003e\\n        \u003cmain class=\\\"main-content\\\" id=\\\"mainContent\\\"\u003e\\n            \u003c!-- 首页 --\u003e\\n            \u003cdiv class=\\\"home-page\\\" id=\\\"homePage\\\"\u003e\\n                \u003cdiv class=\\\"home-title\\\"\u003e\\n                    \u003ch1\u003e🎯 内网工具工作台\u003c/h1\u003e\\n                    \u003cp\u003e简洁高效的在线工具集合，为您的日常工作提供便利\u003c/p\u003e\\n                \u003c/div\u003e\\n                \u003cdiv class=\\\"tool-cards\\\"\u003e\\n                    \u003c!-- Base64 工具卡片 --\u003e\\n                    \u003cdiv class=\\\"tool-card base64\\\" onclick=\\\"openTool('base64')\\\"\u003e\\n                        \u003cdiv class=\\\"card-icon\\\"\u003e🔐\u003c/div\u003e\\n                        \u003ch3\u003eBase64 编解码\u003c/h3\u003e\\n                        \u003cp\u003e支持文本的 Base64 编码和解码，适用于数据传输、配置加密等场景。提供批量处理和错误提示功能。\u003c/p\u003e\\n                    \u003c/div\u003e\\n\\n                    \u003c!-- JSON 工具卡片 --\u003e\\n                    \u003cdiv class=\\\"tool-card json\\\" onclick=\\\"openTool('json')\\\"\u003e\\n                        \u003cdiv class=\\\"card-icon\\\"\u003e📋\u003c/div\u003e\\n                        \u003ch3\u003eJSON 工具集\u003c/h3\u003e\\n                        \u003cp\u003eJSON 格式验证、格式化美化、压缩去除空格，以及两个 JSON 内容的对比功能。支持语法错误定位和高亮显示。\u003c/p\u003e\\n                    \u003c/div\u003e\\n\\n                    \u003c!-- 时间戳工具卡片 --\u003e\\n                    \u003cdiv class=\\\"tool-card timestamp\\\" onclick=\\\"openTool('timestamp')\\\"\u003e\\n                        \u003cdiv class=\\\"card-icon\\\"\u003e⏰\u003c/div\u003e\\n                        \u003ch3\u003e时间戳转换\u003c/h3\u003e\\n                        \u003cp\u003eUnix 时间戳与本地时间的双向转换，支持秒和毫秒格式。自动识别当前时区，提供多种时间显示格式。\u003c/p\u003e\\n                    \u003c/div\u003e\\n                \u003c/div\u003e\\n            \u003c/div\u003e\\n\\n            \u003c!-- Base64 工具页面 --\u003e\\n            \u003cdiv class=\\\"tool-page hidden\\\" id=\\\"base64Page\\\"\u003e\\n                \u003cdiv class=\\\"tool-page-header\\\"\u003e\\n                    \u003cdiv class=\\\"page-icon\\\" style=\\\"background: linear-gradient(135deg, #667eea, #764ba2); color: white;\\\"\u003e🔐\u003c/div\u003e\\n                    \u003ch2\u003eBase64 编解码工具\u003c/h2\u003e\\n                \u003c/div\u003e\\n\\n                \u003cdiv class=\\\"tool-section\\\"\u003e\\n                    \u003ch3\u003e📝 输入内容\u003c/h3\u003e\\n                    \u003cdiv class=\\\"input-group\\\"\u003e\\n                        \u003ctextarea id=\\\"base64Input\\\" placeholder=\\\"请输入要处理的内容...\\\"\u003e\u003c/textarea\u003e\\n                    \u003c/div\u003e\\n                \u003c/div\u003e\\n\\n                \u003cdiv class=\\\"tool-section\\\"\u003e\\n                    \u003cdiv class=\\\"btn-group\\\"\u003e\\n                        \u003cbutton class=\\\"btn btn-primary\\\" onclick=\\\"encodeBase64()\\\"\u003e\\n                            🔄 Base64 编码\\n                        \u003c/button\u003e\\n                        \u003cbutton class=\\\"btn btn-secondary\\\" onclick=\\\"decodeBase64()\\\"\u003e\\n                            🔓 Base64 解码\\n                        \u003c/button\u003e\\n                        \u003cbutton class=\\\"btn btn-success\\\" onclick=\\\"clearBase64()\\\"\u003e\\n                            🗑️ 清空内容\\n                        \u003c/button\u003e\\n                    \u003c/div\u003e\\n                \u003c/div\u003e\\n\\n                \u003cdiv class=\\\"result-area\\\"\u003e\\n                    \u003ch4\u003e📊 处理结果\u003c/h4\u003e\\n                    \u003cdiv class=\\\"result-content\\\" id=\\\"base64Result\\\"\u003e\u003c/div\u003e\\n                    \u003cdiv class=\\\"status-bar hidden\\\" id=\\\"base64Status\\\"\u003e\u003c/div\u003e\\n                \u003c/div\u003e\\n            \u003c/div\u003e\\n\\n            \u003c!-- JSON 工具页面 --\u003e\\n            \u003cdiv class=\\\"tool-page hidden\\\" id=\\\"jsonPage\\\"\u003e\\n                \u003cdiv class=\\\"tool-page-header\\\"\u003e\\n                    \u003cdiv class=\\\"page-icon\\\" style=\\\"background: linear-gradient(135deg, #f093fb, #f5576c); color: white;\\\"\u003e📋\u003c/div\u003e\\n                    \u003ch2\u003eJSON 工具集\u003c/h2\u003e\\n                \u003c/div\u003e\\n\\n                \u003cdiv class=\\\"tool-section\\\"\u003e\\n                    \u003ch3\u003e✅ 格式验证与格式化\u003c/h3\u003e\\n                    \u003cdiv class=\\\"input-group\\\"\u003e\\n                        \u003ctextarea id=\\\"jsonInput\\\" placeholder='请输入 JSON 内容，例如：{\\\"name\\\":\\\"test\\\",\\\"value\\\":123}'\u003e\u003c/textarea\u003e\\n                    \u003c/div\u003e\\n                    \u003cdiv class=\\\"btn-group\\\"\u003e\\n                        \u003cbutton class=\\\"btn btn-primary\\\" onclick=\\\"validateAndFormatJSON()\\\"\u003e\\n                            🔍 验证并格式化\\n                        \u003c/button\u003e\\n                        \u003cbutton class=\\\"btn btn-secondary\\\" onclick=\\\"compressJSON()\\\"\u003e\\n                            📦 压缩（去除空格）\\n                        \u003c/button\u003e\\n                        \u003cbutton class=\\\"btn btn-success\\\" onclick=\\\"copyJsonResult()\\\"\u003e\\n                            📋 复制结果\\n                        \u003c/button\u003e\\n                        \u003cbutton class=\\\"btn btn-secondary\\\" onclick=\\\"clearJson()\\\"\u003e\\n                            🗑️ 清空\\n                        \u003c/button\u003e\\n                    \u003c/div\u003e\\n                \u003c/div\u003e\\n\\n                \u003cdiv class=\\\"result-area\\\"\u003e\\n                    \u003ch4\u003e📊 格式化结果\u003c/h4\u003e\\n                    \u003cdiv class=\\\"result-content\\\" id=\\\"jsonResult\\\"\u003e\u003c/div\u003e\\n                    \u003cdiv class=\\\"status-bar hidden\\\" id=\\\"jsonStatus\\\"\u003e\u003c/div\u003e\\n                \u003c/div\u003e\\n\\n                \u003cdiv class=\\\"tool-section\\\" style=\\\"margin-top: 30px;\\\"\u003e\\n                    \u003ch3\u003e⚖️ JSON 对比\u003c/h3\u003e\\n                    \u003cp style=\\\"color: #7f8c8d; margin-bottom: 15px;\\\"\u003e输入两个 JSON 内容进行对比，检测差异\u003c/p\u003e\\n                    \u003cdiv class=\\\"compare-container\\\"\u003e\\n                        \u003cdiv class=\\\"compare-panel\\\"\u003e\\n                            \u003ch4\u003eJSON A\u003c/h4\u003e\\n                            \u003ctextarea id=\\\"jsonCompareA\\\" placeholder=\\\"请输入第一个 JSON 内容...\\\" style=\\\"min-height: 200px;\\\"\u003e\u003c/textarea\u003e\\n                        \u003c/div\u003e\\n                        \u003cdiv class=\\\"compare-panel\\\"\u003e\\n                            \u003ch4\u003eJSON B\u003c/h4\u003e\\n                            \u003ctextarea id=\\\"jsonCompareB\\\" placeholder=\\\"请输入第二个 JSON 内容...\\\" style=\\\"min-height: 200px;\\\"\u003e\u003c/textarea\u003e\\n                        \u003c/div\u003e\\n                    \u003c/div\u003e\\n                    \u003cdiv class=\\\"btn-group\\\" style=\\\"margin-top: 15px;\\\"\u003e\\n                        \u003cbutton class=\\\"btn btn-primary\\\" onclick=\\\"compareJSON()\\\"\u003e\\n                            🔀 开始对比\\n                        \u003c/button\u003e\\n                        \u003cbutton class=\\\"btn btn-secondary\\\" onclick=\\\"clearJsonCompare()\\\"\u003e\\n                            🗑️ 清空对比\\n                        \u003c/button\u003e\\n                    \u003c/div\u003e\\n                \u003c/div\u003e\\n\\n                \u003cdiv class=\\\"result-area\\\"\u003e\\n                    \u003ch4\u003e🔍 对比结果\u003c/h4\u003e\\n                    \u003cdiv class=\\\"result-content\\\" id=\\\"jsonCompareResult\\\"\u003e\u003c/div\u003e\\n                    \u003cdiv class=\\\"status-bar hidden\\\" id=\\\"jsonCompareStatus\\\"\u003e\u003c/div\u003e\\n                \u003c/div\u003e\\n            \u003c/div\u003e\\n\\n            \u003c!-- 时间戳工具页面 --\u003e\\n            \u003cdiv class=\\\"tool-page hidden\\\" id=\\\"timestampPage\\\"\u003e\\n                \u003cdiv class=\\\"tool-page-header\\\"\u003e\\n                    \u003cdiv class=\\\"page-icon\\\" style=\\\"background: linear-gradient(135deg, #4facfe, #00f2fe); color: white;\\\"\u003e⏰\u003c/div\u003e\\n                    \u003ch2\u003e时间戳转换工具\u003c/h2\u003e\\n                \u003c/div\u003e\\n\\n                \u003cdiv class=\\\"tool-section\\\"\u003e\\n                    \u003ch3\u003e🔄 双向转换\u003c/h3\u003e\\n                    \u003cp style=\\\"color: #7f8c8d; margin-bottom: 15px;\\\"\u003e支持 Unix 时间戳（秒/毫秒）与本地时间的相互转换\u003c/p\u003e\\n                    \\n                    \u003cdiv class=\\\"input-group\\\"\u003e\\n                        \u003clabel for=\\\"timestampInput\\\"\u003e输入内容：\u003c/label\u003e\\n                        \u003cinput type=\\\"text\\\" id=\\\"timestampInput\\\" placeholder=\\\"请输入时间戳（数字）或日期时间字符串\\\"\u003e\\n                    \u003c/div\u003e\\n\\n                    \u003cdiv class=\\\"btn-group\\\"\u003e\\n                        \u003cbutton class=\\\"btn btn-primary\\\" onclick=\\\"convertTimestampToDate()\\\"\u003e\\n                            📅 时间戳 → 日期\\n                        \u003c/button\u003e\\n                        \u003cbutton class=\\\"btn btn-secondary\\\" onclick=\\\"convertDateToTimestamp()\\\"\u003e\\n                            🕐 日期 → 时间戳\\n                        \u003c/button\u003e\\n                        \u003cbutton class=\\\"btn btn-success\\\" onclick=\\\"getCurrentTimestamp()\\\"\u003e\\n                            ⏱️ 获取当前时间戳\\n                        \u003c/button\u003e\\n                        \u003cbutton class=\\\"btn btn-secondary\\\" onclick=\\\"clearTimestamp()\\\"\u003e\\n                            🗑️ 清空\\n                        \u003c/button\u003e\\n                    \u003c/div\u003e\\n                \u003c/div\u003e\\n\\n                \u003cdiv class=\\\"result-area\\\"\u003e\\n                    \u003ch4\u003e📊 转换结果\u003c/h4\u003e\\n                    \u003cdiv class=\\\"result-content\\\" id=\\\"timestampResult\\\"\u003e\u003c/div\u003e\\n                    \u003cdiv class=\\\"status-bar hidden\\\" id=\\\"timestampStatus\\\"\u003e\u003c/div\u003e\\n                \u003c/div\u003e\\n\\n                \u003cdiv class=\\\"tool-section\\\" style=\\\"margin-top: 20px;\\\"\u003e\\n                    \u003ch3\u003eℹ️ 当前时区信息\u003c/h3\u003e\\n                    \u003cdiv class=\\\"result-area\\\"\u003e\\n                        \u003cdiv class=\\\"result-content\\\" id=\\\"timezoneInfo\\\"\u003e\u003c/div\u003e\\n                    \u003c/div\u003e\\n                \u003c/div\u003e\\n            \u003c/div\u003e\\n        \u003c/main\u003e\\n    \u003c/div\u003e\\n\\n    \u003cscript\u003e\\n        // 工具状态管理\\n        const toolState = {\\n            openedTools: ['home'],\\n            currentTool: 'home',\\n            tools: {\\n                home: { name: '首页', icon: '🏠', closable: false },\\n                base64: { name: 'Base64 编解码', icon: '🔐', closable: true },\\n                json: { name: 'JSON 工具集', icon: '📋', closable: true },\\n                timestamp: { name: '时间戳转换', icon: '⏰', closable: true }\\n            }\\n        };\\n\\n        // 初始化\\n        document.addEventListener('DOMContentLoaded', function() {\\n            renderToolList();\\n            showHomePage();\\n            displayTimezoneInfo();\\n        });\\n\\n        // 渲染工具列表\\n        function renderToolList() {\\n            const toolList = document.getElementById('toolList');\\n            toolList.innerHTML = '';\\n\\n            toolState.openedTools.forEach(toolId =\u003e {\\n                const tool = toolState.tools[toolId];\\n                if (!tool) return;\\n\\n                const item = document.createElement('div');\\n                item.className = `tool-item ${toolState.currentTool === toolId ? 'active' : ''}`;\\n                item.onclick = (e) =\u003e {\\n                    if (!e.target.classList.contains('close-btn')) {\\n                        switchToTool(toolId);\\n                    }\\n                };\\n\\n                const closeBtnClass = tool.closable ? '' : 'hidden';\\n                \\n                item.innerHTML = `\\n                    \u003cdiv class=\\\"name\\\"\u003e\\n                        \u003cspan class=\\\"icon\\\"\u003e${tool.icon}\u003c/span\u003e\\n                        \u003cspan\u003e${tool.name}\u003c/span\u003e\\n                    \u003c/div\u003e\\n                    \u003cbutton class=\\\"close-btn ${closeBtnClass}\\\" \\n                            onclick=\\\"closeTool('${toolId}', event)\\\"\\n                            title=\\\"${tool.closable ? '关闭工具' : '首页不可关闭'}\\\"\u003e\\n                        ×\\n                    \u003c/button\u003e\\n                `;\\n\\n                toolList.appendChild(item);\\n            });\\n        }\\n\\n        // 显示首页\\n        function showHomePage() {\\n            document.getElementById('homePage').classList.remove('hidden');\\n            document.getElementById('base64Page').classList.add('hidden');\\n            document.getElementById('jsonPage').classList.add('hidden');\\n            document.getElementById('timestampPage').classList.add('hidden');\\n        }\\n\\n        // 打开工具\\n        function openTool(toolId) {\\n            if (!toolState.openedTools.includes(toolId)) {\\n                toolState.openedTools.push(toolId);\\n            }\\n            switchToTool(toolId);\\n        }\\n\\n        // 切换到指定工具\\n        function switchToTool(toolId) {\\n            toolState.currentTool = toolId;\\n            \\n            // 隐藏所有页面\\n            showHomePage();\\n            \\n            // 显示对应页面\\n            if (toolId === 'home') {\\n                document.getElementById('homePage').classList.remove('hidden');\\n            } else if (toolId === 'base64') {\\n                document.getElementById('base64Page').classList.remove('hidden');\\n            } else if (toolId === 'json') {\\n                document.getElementById('jsonPage').classList.remove('hidden');\\n            } else if (toolId === 'timestamp') {\\n                document.getElementById('timestampPage').classList.remove('hidden');\\n            }\\n\\n            renderToolList();\\n        }\\n\\n        // 关闭工具\\n        function closeTool(toolId, event) {\\n            event.stopPropagation();\\n            \\n            const index = toolState.openedTools.indexOf(toolId);\\n            if (index \u003e -1) {\\n                toolState.openedTools.splice(index, 1);\\n            }\\n\\n            // 切换回首页\\n            toolState.currentTool = 'home';\\n            showHomePage();\\n            renderToolList();\\n        }\\n\\n        // ==================== Base64 工具功能 ====================\\n        \\n        function encodeBase64() {\\n            const input = document.getElementById('base64Input').value;\\n            const resultDiv = document.getElementById('base64Result');\\n            const statusDiv = document.getElementById('base64Status');\\n\\n            if (!input.trim()) {\\n                showResult(resultDiv, '请输入要编码的内容', 'error');\\n                showStatus(statusDiv, '⚠️ 输入内容不能为空', 'error');\\n                return;\\n            }\\n\\n            try {\\n                // 使用 UTF-8 编码支持中文\\n                const encoded = btoa(unescape(encodeURIComponent(input)));\\n                showResult(resultDiv, encoded, 'success');\\n                showStatus(statusDiv, `✓ 编码成功，结果长度：${encoded.length} 字符`, 'success');\\n            } catch (error) {\\n                showResult(resultDiv, error.message, 'error');\\n                showStatus(statusDiv, '✗ 编码失败', 'error');\\n            }\\n        }\\n\\n        function decodeBase64() {\\n            const input = document.getElementById('base64Input').value;\\n            const resultDiv = document.getElementById('base64Result');\\n            const statusDiv = document.getElementById('base64Status');\\n\\n            if (!input.trim()) {\\n                showResult(resultDiv, '请输入要解码的 Base64 内容', 'error');\\n                showStatus(statusDiv, '⚠️ 输入内容不能为空', 'error');\\n                return;\\n            }\\n\\n            try {\\n                // 验证 Base64 格式\\n                if (!/^[A-Za-z0-9+/]*={0,2}$/.test(input.trim())) {\\n                    throw new Error('无效的 Base64 格式');\\n                }\\n\\n                const decoded = decodeURIComponent(escape(atob(input.trim())));\\n                showResult(resultDiv, decoded, 'success');\\n                showStatus(statusDiv, `✓ 解码成功，结果长度：${decoded.length} 字符`, 'success');\\n            } catch (error) {\\n                showResult(resultDiv, error.message, 'error');\\n                showStatus(statusDiv, '✗ 解码失败，请检查输入是否为有效的 Base64 内容', 'error');\\n            }\\n        }\\n\\n        function clearBase64() {\\n            document.getElementById('base64Input').value = '';\\n            document.getElementById('base64Result').innerHTML = '';\\n            document.getElementById('base64Status').classList.add('hidden');\\n        }\\n\\n        // ==================== JSON 工具功能 ====================\\n\\n        function validateAndFormatJSON() {\\n            const input = document.getElementById('jsonInput').value;\\n            const resultDiv = document.getElementById('jsonResult');\\n            const statusDiv = document.getElementById('jsonStatus');\\n\\n            if (!input.trim()) {\\n                showResult(resultDiv, '请输入 JSON 内容', 'error');\\n                showStatus(statusDiv, '⚠️ 输入内容不能为空', 'error');\\n                return;\\n            }\\n\\n            try {\\n                const parsed = JSON.parse(input);\\n                const formatted = JSON.stringify(parsed, null, 2);\\n                \\n                // 高亮显示\\n                const highlighted = highlightJSON(formatted);\\n                resultDiv.innerHTML = highlighted;\\n                resultDiv.className = 'result-content success json-highlight';\\n                \\n                showStatus(statusDiv, '✓ JSON 格式正确，已格式化', 'success');\\n            } catch (error) {\\n                const errorMsg = error.message;\\n                const positionMatch = errorMsg.match(/at position (\\\\d+)/);\\n                let detailMsg = errorMsg;\\n                if (positionMatch) {\\n                    const pos = parseInt(positionMatch[1]);\\n                    detailMsg += `\\\\n\\\\n错误位置：第 ${pos} 个字符附近`;\\n                }\\n                \\n                showResult(resultDiv, detailMsg, 'error');\\n                showStatus(statusDiv, '✗ JSON 格式验证失败', 'error');\\n            }\\n        }\\n\\n        function compressJSON() {\\n            const input = document.getElementById('jsonInput').value;\\n            const resultDiv = document.getElementById('jsonResult');\\n            const statusDiv = document.getElementById('jsonStatus');\\n\\n            if (!input.trim()) {\\n                showResult(resultDiv, '请输入 JSON 内容', 'error');\\n                return;\\n            }\\n\\n            try {\\n                const parsed = JSON.parse(input);\\n                const compressed = JSON.stringify(parsed);\\n                \\n                const originalLength = input.length;\\n                const compressionRate = ((1 - compressed.length / originalLength) * 100).toFixed(2);\\n                \\n                showResult(resultDiv, compressed, 'success');\\n                showStatus(statusDiv, \\n                    `✓ 压缩成功\\\\n原长度：${originalLength} 字符，压缩后：${compressed.length} 字符，压缩率：${compressionRate}%`, \\n                    'success');\\n            } catch (error) {\\n                showResult(resultDiv, error.message, 'error');\\n                showStatus(statusDiv, '✗ JSON 格式错误，无法压缩', 'error');\\n            }\\n        }\\n\\n        function copyJsonResult() {\\n            const result = document.getElementById('jsonResult').textContent;\\n            if (!result.trim()) {\\n                alert('没有可复制的内容');\\n                return;\\n            }\\n\\n            // 兼容 file://协议的剪贴板操作\\n            copyToClipboard(result);\\n            showStatus(document.getElementById('jsonStatus'), '✓ 结果已复制到剪贴板', 'success');\\n        }\\n\\n        function clearJson() {\\n            document.getElementById('jsonInput').value = '';\\n            document.getElementById('jsonResult').innerHTML = '';\\n            document.getElementById('jsonStatus').classList.add('hidden');\\n        }\\n\\n        // JSON 对比功能\\n        function compareJSON() {\\n            const jsonA = document.getElementById('jsonCompareA').value;\\n            const jsonB = document.getElementById('jsonCompareB').value;\\n            const resultDiv = document.getElementById('jsonCompareResult');\\n            const statusDiv = document.getElementById('jsonCompareStatus');\\n\\n            if (!jsonA.trim() || !jsonB.trim()) {\\n                showResult(resultDiv, '请同时在两个输入框中输入 JSON 内容', 'error');\\n                showStatus(statusDiv, '⚠️ 两个 JSON 输入都不能为空', 'error');\\n                return;\\n            }\\n\\n            try {\\n                const parsedA = JSON.parse(jsonA);\\n                const parsedB = JSON.parse(jsonB);\\n\\n                const stringA = JSON.stringify(parsedA, null, 2);\\n                const stringB = JSON.stringify(parsedB, null, 2);\\n\\n                if (stringA === stringB) {\\n                    showResult(resultDiv, '✅ 两个 JSON 内容完全相同', 'success');\\n                    showStatus(statusDiv, '✓ 对比完成：JSON A 和 JSON B 内容一致', 'success');\\n                } else {\\n                    const differences = findDifferences(parsedA, parsedB);\\n                    let diffText = '📋 差异分析：\\\\n\\\\n';\\n                    if (differences.length === 0) {\\n                        diffText += '结构相同，但存在值差异（可能为顺序不同）';\\n                    } else {\\n                        differences.forEach((diff, index) =\u003e {\\n                            diffText += `${index + 1}. ${diff.path}: ${diff.description}\\\\n`;\\n                        });\\n                    }\\n                    \\n                    showResult(resultDiv, diffText, 'success');\\n                    showStatus(statusDiv, '✓ 对比完成：发现差异', 'success');\\n                }\\n            } catch (error) {\\n                let errorMsg = error.message;\\n                if (error instanceof SyntaxError) {\\n                    errorMsg = 'JSON 格式错误：' + error.message;\\n                }\\n                showResult(resultDiv, errorMsg, 'error');\\n                showStatus(statusDiv, '✗ 对比失败，请检查 JSON 格式', 'error');\\n            }\\n        }\\n\\n        function findDifferences(objA, objB, path = '') {\\n            const differences = [];\\n            \\n            const keysA = Object.keys(objA).sort();\\n            const keysB = Object.keys(objB).sort();\\n\\n            // 检查键的差异\\n            const allKeys = [...new Set([...keysA, ...keysB])];\\n            \\n            allKeys.forEach(key =\u003e {\\n                const currentPath = path ? `${path}.${key}` : key;\\n                const inA = keysA.includes(key);\\n                const inB = keysB.includes(key);\\n\\n                if (!inA) {\\n                    differences.push({ path: currentPath, description: `仅在 JSON B 中存在` });\\n                } else if (!inB) {\\n                    differences.push({ path: currentPath, description: `仅在 JSON A 中存在` });\\n                } else {\\n                    const valA = objA[key];\\n                    const valB = objB[key];\\n                    const typeA = typeof valA;\\n                    const typeB = typeof valB;\\n\\n                    if (typeA !== typeB) {\\n                        differences.push({ \\n                            path: currentPath, \\n                            description: `类型不同：JSON A 为 ${typeA}，JSON B 为 ${typeB}` \\n                        });\\n                    } else if (Array.isArray(valA) \u0026\u0026 Array.isArray(valB)) {\\n                        if (valA.length !== valB.length) {\\n                            differences.push({ \\n                                path: currentPath, \\n                                description: `数组长度不同：JSON A = ${valA.length}, JSON B = ${valB.length}` \\n                            });\\n                        }\\n                    } else if (typeof valA === 'object' \u0026\u0026 valA !== null \u0026\u0026 typeof valB === 'object' \u0026\u0026 valB !== null) {\\n                        differences.push(...findDifferences(valA, valB, currentPath));\\n                    } else if (JSON.stringify(valA) !== JSON.stringify(valB)) {\\n                        differences.push({ \\n                            path: currentPath, \\n                            description: `值不同：JSON A = ${JSON.stringify(valA)}, JSON B = ${JSON.stringify(valB)}` \\n                        });\\n                    }\\n                }\\n            });\\n\\n            return differences;\\n        }\\n\\n        function clearJsonCompare() {\\n            document.getElementById('jsonCompareA').value = '';\\n            document.getElementById('jsonCompareB').value = '';\\n            document.getElementById('jsonCompareResult').innerHTML = '';\\n            document.getElementById('jsonCompareStatus').classList.add('hidden');\\n        }\\n\\n        // JSON 高亮显示\\n        function highlightJSON(jsonString) {\\n            return jsonString\\n                .replace(/\u0026/g, '\u0026amp;')\\n                .replace(/\u003c/g, '\u0026lt;')\\n                .replace(/\u003e/g, '\u0026gt;')\\n                .replace(/(\\\"(\\\\\\\\u[a-zA-Z0-9]{4}|\\\\\\\\[^u]|[^\\\\\\\\\\\"])*\\\"(\\\\s*:)?|\\\\b(true|false|null)\\\\b|-?\\\\d+(?:\\\\.\\\\d*)?(?:[eE][+\\\\-]?\\\\d+)?)/g, function (match) {\\n                    let cls = 'json-number';\\n                    if (/^\\\"/.test(match)) {\\n                        if (/:$/.test(match)) {\\n                            cls = 'json-key';\\n                        } else {\\n                            cls = 'json-string';\\n                        }\\n                    } else if (/true|false/.test(match)) {\\n                        cls = 'json-boolean';\\n                    } else if (/null/.test(match)) {\\n                        cls = 'json-null';\\n                    }\\n                    return '\u003cspan class=\\\"' + cls + '\\\"\u003e' + match + '\u003c/span\u003e';\\n                });\\n        }\\n\\n        // ==================== 时间戳工具功能 ====================\\n\\n        function convertTimestampToDate() {\\n            const input = document.getElementById('timestampInput').value.trim();\\n            const resultDiv = document.getElementById('timestampResult');\\n            const statusDiv = document.getElementById('timestampStatus');\\n\\n            if (!input) {\\n                showResult(resultDiv, '请输入时间戳（数字格式）', 'error');\\n                showStatus(statusDiv, '⚠️ 输入内容不能为空', 'error');\\n                return;\\n            }\\n\\n            // 判断是秒还是毫秒\\n            const num = Number(input);\\n            if (isNaN(num)) {\\n                showResult(resultDiv, '请输入有效的数字时间戳', 'error');\\n                showStatus(statusDiv, '✗ 输入格式错误', 'error');\\n                return;\\n            }\\n\\n            // 判断是秒还是毫秒（10 位为秒，13 位为毫秒）\\n            const isSeconds = num.toString().length \u003c= 10;\\n            const timestamp = isSeconds ? num * 1000 : num;\\n            \\n            const date = new Date(timestamp);\\n            \\n            if (isNaN(date.getTime())) {\\n                showResult(resultDiv, '时间戳超出有效范围', 'error');\\n                showStatus(statusDiv, '✗ 转换失败', 'error');\\n                return;\\n            }\\n\\n            const result = formatTimestampResult(date, isSeconds, num);\\n            showResult(resultDiv, result, 'success');\\n            showStatus(statusDiv, `✓ 转换成功（${isSeconds ? '秒' : '毫秒'}级时间戳）`, 'success');\\n        }\\n\\n        function convertDateToTimestamp() {\\n            const input = document.getElementById('timestampInput').value.trim();\\n            const resultDiv = document.getElementById('timestampResult');\\n            const statusDiv = document.getElementById('timestampStatus');\\n\\n            if (!input) {\\n                showResult(resultDiv, '请输入日期时间字符串', 'error');\\n                showStatus(statusDiv, '⚠️ 输入内容不能为空', 'error');\\n                return;\\n            }\\n\\n            const date = new Date(input);\\n            \\n            if (isNaN(date.getTime())) {\\n                showResult(resultDiv, '无法解析日期格式，请检查输入', 'error');\\n                showStatus(statusDiv, '✗ 日期格式错误', 'error');\\n                return;\\n            }\\n\\n            const timestampMs = date.getTime();\\n            const timestampSec = Math.floor(timestampMs / 1000);\\n\\n            const result = `📅 原始输入：${input}\\\\n\\\\n` +\\n                          `⏰ Unix 时间戳（毫秒）: ${timestampMs}\\\\n` +\\n                          `⏱️ Unix 时间戳（秒）: ${timestampSec}\\\\n\\\\n` +\\n                          `📋 解析后的日期：${date.toLocaleString('zh-CN')}`;\\n\\n            showResult(resultDiv, result, 'success');\\n            showStatus(statusDiv, '✓ 转换成功', 'success');\\n        }\\n\\n        function getCurrentTimestamp() {\\n            const now = new Date();\\n            const timestampMs = now.getTime();\\n            const timestampSec = Math.floor(timestampMs / 1000);\\n\\n            document.getElementById('timestampInput').value = '';\\n            \\n            const resultDiv = document.getElementById('timestampResult');\\n            const statusDiv = document.getElementById('timestampStatus');\\n\\n            const result = `🕐 当前时间：${now.toLocaleString('zh-CN', { \\n                year: 'numeric', \\n                month: '2-digit', \\n                day: '2-digit', \\n                hour: '2-digit', \\n                minute: '2-digit', \\n                second: '2-digit' \\n            })}\\\\n\\\\n` +\\n                          `⏰ Unix 时间戳（毫秒）: ${timestampMs}\\\\n` +\\n                          `⏱️ Unix 时间戳（秒）: ${timestampSec}`;\\n\\n            showResult(resultDiv, result, 'success');\\n            showStatus(statusDiv, '✓ 已获取当前时间戳', 'success');\\n        }\\n\\n        function clearTimestamp() {\\n            document.getElementById('timestampInput').value = '';\\n            document.getElementById('timestampResult').innerHTML = '';\\n            document.getElementById('timestampStatus').classList.add('hidden');\\n        }\\n\\n        function formatTimestampResult(date, isSeconds, originalValue) {\\n            const options = {\\n                year: 'numeric',\\n                month: '2-digit',\\n                day: '2-digit',\\n                hour: '2-digit',\\n                minute: '2-digit',\\n                second: '2-digit',\\n                timeZoneName: 'short'\\n            };\\n\\n            const formattedDate = new Intl.DateTimeFormat('zh-CN', options).format(date);\\n\\n            return `📊 时间戳信息\\\\n\\\\n` +\\n                   `原始值：${originalValue}\\\\n` +\\n                   `类型：${isSeconds ? '秒级时间戳' : '毫秒级时间戳'}\\\\n\\\\n` +\\n                   `📅 转换结果（本地时区）:\\\\n` +\\n                   `${formattedDate}\\\\n\\\\n` +\\n                   `详细格式:\\\\n` +\\n                   `年 - 月 - 日：${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}\\\\n` +\\n                   `时：分:秒：${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')}:${String(date.getSeconds()).padStart(2, '0')}\\\\n` +\\n                   `时区偏移：${getTimezoneOffset()}`;\\n        }\\n\\n        function displayTimezoneInfo() {\\n            const tzName = Intl.DateTimeFormat().resolvedOptions().timeZone;\\n            const offset = getTimezoneOffset();\\n            \\n            const info = `🌍 当前时区：${tzName}\\\\n` +\\n                        `⏱️ 时区偏移：${offset}\\\\n\\\\n` +\\n                        `💡 提示：\\\\n` +\\n                        `- Unix 时间戳基于 UTC 时间\\\\n` +\\n                        `- 转换结果已根据本地时区自动调整\\\\n` +\\n                        `- 10 位数字为秒级时间戳，13 位为毫秒级`;\\n\\n            document.getElementById('timezoneInfo').textContent = info;\\n        }\\n\\n        function getTimezoneOffset() {\\n            const offsetMinutes = new Date().getTimezoneOffset();\\n            const offsetHours = Math.abs(Math.floor(offsetMinutes / 60));\\n            const offsetSign = offsetMinutes \u003e 0 ? '-' : '+';\\n            return `UTC${offsetSign}${String(offsetHours).padStart(2, '0')}:00`;\\n        }\\n\\n        // ==================== 通用工具函数 ====================\\n\\n        function showResult(element, content, type) {\\n            element.textContent = content;\\n            element.className = 'result-content ' + type;\\n        }\\n\\n        function showStatus(element, message, type) {\\n            element.textContent = message;\\n            element.className = 'status-bar ' + type;\\n            element.classList.remove('hidden');\\n        }\\n\\n        // 兼容 file://协议的剪贴板操作（提供降级方案）\\n        function copyToClipboard(text) {\\n            // 优先使用现代 API\\n            if (navigator.clipboard \u0026\u0026 navigator.clipboard.writeText) {\\n                navigator.clipboard.writeText(text).then(() =\u003e {\\n                    console.log('复制成功');\\n                }).catch(err =\u003e {\\n                    console.log('使用降级方案复制', err);\\n                    fallbackCopyText(text);\\n                });\\n            } else {\\n                // 降级方案：使用 document.execCommand\\n                fallbackCopyText(text);\\n            }\\n        }\\n\\n        function fallbackCopyText(text) {\\n            const textarea = document.createElement('textarea');\\n            textarea.value = text;\\n            textarea.style.position = 'fixed';\\n            textarea.style.left = '-9999px';\\n            textarea.style.top = '0';\\n            \\n            document.body.appendChild(textarea);\\n            textarea.select();\\n            \\n            try {\\n                const successful = document.execCommand('copy');\\n                if (successful) {\\n                    console.log('复制成功（降级方案）');\\n                } else {\\n                    throw new Error('execCommand 失败');\\n                }\\n            } catch (err) {\\n                console.error('复制失败:', err);\\n                alert('复制功能不可用，请手动复制结果');\\n            } finally {\\n                document.body.removeChild(textarea);\\n            }\\n        }\\n\\n        // 键盘快捷键支持\\n        document.addEventListener('keydown', function(e) {\\n            // Ctrl/Cmd + Enter 触发当前页面的主要操作\\n            if ((e.ctrlKey || e.metaKey) \u0026\u0026 e.key === 'Enter') {\\n                if (!document.getElementById('base64Page').classList.contains('hidden')) {\\n                    encodeBase64();\\n                } else if (!document.getElementById('jsonPage').classList.contains('hidden')) {\\n                    validateAndFormatJSON();\\n                } else if (!document.getElementById('timestampPage').classList.contains('hidden')) {\\n                    convertTimestampToDate();\\n                }\\n            }\\n        });\\n    \u003c/script\u003e\\n\u003c/body\u003e\\n\u003c/html\u003e\\n\",\"path\":\"C:\\\\Users\\\\Attect\\\\trae\\\\AgentPlus\\\\project\\\\html-tools\\\\index.html\"}","tool_name":"write_file"}}
